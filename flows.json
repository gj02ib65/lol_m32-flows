    {
        "id": "6c994da91c946887",
        "type": "function",
        "z": "acb1261afd28cef6",
        "name": "Sync Logic Engine (Safes & Sim)",
        "func": "const config = global.get(\"app_config\") || {};\nconst SIM_MODE = (config.sim_mode === true || config.sim_mode === \"true\");\nconst REPLICA_IP = config.replica_ip || \"127.0.0.1\";\n\n// Improved Safe List parsing\nconst SAFE_NAMES = (config.safe_names || \"\")\n    .split(',')\n    .map(s => s.trim().toLowerCase())\n    .filter(s => s.length > 0); // Remove empty entries\n\nlet topic = msg.topic;\nlet payload = Array.isArray(msg.payload) ? msg.payload[0] : msg.payload;\nlet shouldSync = false; // We start by assuming we are NOT syncing\n\nfunction cleanOSC(input) {\n    return (typeof input === 'string') ? input.replace(/\\0/g, '').trim() : input;\n}\n\n// 1. WHITELIST FILTERING & PROCESSING\nif (topic.startsWith(\"/ch/\")) {\n    let chIndex = topic.split('/')[2];\n    let key = `ch_${chIndex}_name`;\n\n    // Only allow specific sub-topics for Channels\n    if (topic.endsWith(\"/config/name\")) {\n        shouldSync = true;\n        let newName = cleanOSC(payload);\n        global.set(key, newName);\n        msg.payload = { type: \"s\", value: newName };\n    } \n    else if (topic.endsWith(\"/mix/on\")) {\n        shouldSync = true;\n        let currentName = (global.get(key) || \"CH \" + chIndex).toLowerCase();\n        let isSafe = SAFE_NAMES.some(word => word && currentName.includes(word));\n        \n        if (isSafe) {\n            node.status({fill:\"yellow\", shape:\"ring\", text: \"Safe: \" + currentName});\n            return [null, { audit: { status: \"BLOCKED\", detail: currentName } }]; \n        }\n        msg.payload = { type: \"i\", value: parseInt(payload) };\n    }\n    else if (topic.endsWith(\"/grp/dca\")) {\n        shouldSync = true;\n        msg.payload = { type: \"i\", value: parseInt(payload) };\n    }\n} \nelse if (topic.startsWith(\"/dca/\")) {\n    // Only allow Name and Mute for DCAs\n    if (topic.endsWith(\"/config/name\") || topic.endsWith(\"/on\")) {\n        shouldSync = true;\n        msg.payload = (topic.endsWith(\"/on\")) \n            ? { type: \"i\", value: parseInt(payload) } \n            : { type: \"s\", value: cleanOSC(payload) };\n    }\n}\n\n// 2. THE GATEKEEPER\n// If the topic didn't match our allowed list above, KILL the message here.\nif (!shouldSync) {\n    return null; \n}\n\n// 3. FINAL ROUTING (Only reached if shouldSync is true)\nmsg.ip = REPLICA_IP;\nmsg.port = 10023;\n\nif (SIM_MODE) {\n    node.status({fill:\"blue\", shape:\"dot\", text: \"SIMULATED\"});\n    return [null, msg];\n} else {\n    node.status({fill:\"green\", shape:\"dot\", text: \"Synced: \" + topic});\n    return [msg, RED.util.cloneMessage(msg)]; \n}",
