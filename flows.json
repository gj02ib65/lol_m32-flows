    {
        "id": "be38de1246053556",
        "type": "function",
        "z": "3c1a1c73431382ea",
        "g": "aeb187c0ea7aedcf",
        "name": "Query Primary Desk",
        "func": "const config = global.get('app_config');\n\nif (!config || !config.primary_ip) {\n    node.status({ fill: \"red\", shape: \"ring\", text: \"No Primary IP\" });\n    return null;\n}\n\nconst PRIMARY_IP = config.primary_ip;\nconst PORT = 10023;\n\n// We send an empty array [] as payload because the OSC Encoder \n// has \"Metadata\" enabled and expects an arguments list.\nfor (let i = 1; i <= 32; i++) {\n    let ch = i.toString().padStart(2, '0');\n    node.send({ topic: `/ch/${ch}/config/name`, payload: [], ip: PRIMARY_IP, port: PORT });\n    node.send({ topic: `/ch/${ch}/mix/on`, payload: [], ip: PRIMARY_IP, port: PORT });\n    node.send({ topic: `/ch/${ch}/grp/dca`, payload: [], ip: PRIMARY_IP, port: PORT });\n}\n\nfor (let j = 1; j <= 8; j++) {\n    node.send({ topic: `/dca/${j}/config/name`, payload: [], ip: PRIMARY_IP, port: PORT });\n    node.send({ topic: `/dca/${j}/on`, payload: [], ip: PRIMARY_IP, port: PORT });\n}\n\nnode.status({ fill: \"green\", shape: \"dot\", text: \"Syncing Names & Mutes...\" });\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
